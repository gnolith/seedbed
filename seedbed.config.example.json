{
  "databasePath": "./.seedbed/gnolith.sqlite",
  "blobPath": "./.seedbed/blobs",
  "busyTimeoutMs": 5000,
  "baseIri": "https://example.invalid/gnolith/",
  "rootSecretFile": "/run/secrets/seedbed-root",
  "principalSelector": "owner",
  "workspaceSelector": "primary",
  "logLevel": "info",
  "shutdownTimeoutMs": 10000,
  "semanticConfigurations": [
    {
      "id": "local-ollama",
      "name": "Local Ollama with SQLite vectors",
      "selected": true,
      "provider": {
        "kind": "ollama-compatible",
        "endpoint": "http://127.0.0.1:11434",
        "model": "nomic-embed-text",
        "dimensions": 768,
        "allowPrivateEndpoint": true
      },
      "vectorIndex": { "kind": "sqlite" }
    }
  ]
}

